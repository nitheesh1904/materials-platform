# ------------------ Equilibration (NVT/NPT) ---------
reset_timestep  0
velocity all create ${temperature} 87287 loop geom
velocity all create 600 87287 loop geom

# Reference timestep for metal units with Silicon is typically 1-2 fs
timestep        0.001


# Tdamp - 100*Timestep
# Pdamp - 1000*Timestep
#
# Run NPT to fix temperature at 300K and pressure at 0 Bar
fix 1 all npt temp ${temperature} ${temperature} 0.1 iso ${pressure} ${pressure} 1.0
fix 1 all npt temp 600 ${temperature} 0.1 iso ${pressure} ${pressure} 1.0
fix 1 all npt temp 600 600 0.1 iso ${pressure} ${pressure} 1.0
fix 1 all npt temp 600 600 0.1 iso 0.0 ${pressure} 1.0
fix 1 all npt temp 600 600 0.1 iso 0.0 0.0 1.0

# Output settings

variable dump_path string "../results/lattice_parameter/si_out_${temperature}.dat"
../results/lattice_parameter/si_out_600.dat

dump 1 all custom 5000 ${dump_path} mass type xs ys zs
dump 1 all custom 5000 ../results/lattice_parameter/si_out_600.dat mass type xs ys zs

dump_modify 1 sort id

variable first_run_step equal ${steps}
variable first_run_step equal 50000

# Run the simulation
run ${first_run_step}
run 50000
